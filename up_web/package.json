{
  "name": "up_web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "kill -9 $(lsof -ti :3100) 2>/dev/null || true; sleep 0.5; env-cmd -f .env.bypass.local next dev --turbopack --port 3100",
    "dev:auth": "next dev --turbopack --port 3100",
    "dev:online": "env-cmd -f .env.bypass next dev --turbopack --port 3100",
    "build": "next build",
    "start": "PORT=3100 env-cmd -f .env next start",
    "start:bypass": "PORT=3100 env-cmd -f .env.bypass.local next start",
    "start:online": "PORT=3100 env-cmd -f .env next start",
    "lint": "eslint .",
    "db:reset": "cd ../supabase && supabase db reset --local",
    "db:reset:full": "cd ../supabase && supabase db reset --local && supabase --experimental storage cp -r storage/avatars ss:///avatars --local",
    "db:seed": "cd ../supabase && supabase db reset --local",
    "db:migrate": "cd ../supabase && supabase migration new",
    "db:diff": "cd ../supabase && supabase db diff --local",
    "db:push": "cd ../supabase && supabase db push --local",
    "db:pull": "cd ../supabase && supabase db pull --local",
    "db:status": "cd ../supabase && supabase status",
    "db:studio": "cd ../supabase && supabase studio",
    "db:reset:remote": "cd ../supabase && supabase db reset --linked",
    "db:sync:remote": "cd ../supabase && supabase db push --linked",
    "storage:seed": "cd ../supabase && supabase --experimental storage cp -r storage/avatars ss:///avatars --local",
    "storage:push:remote": "cd ../supabase && supabase --experimental storage cp -r storage/avatars ss:///avatars --linked",
    "supabase:start": "cd ../supabase && supabase start",
    "supabase:stop": "cd ../supabase && supabase stop",
    "supabase:status": "cd ../supabase && supabase status"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.5",
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "ai": "^6.0.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "googleapis": "^169.0.0",
    "jose": "^6.1.3",
    "lucide-react": "^0.511.0",
    "mammoth": "^1.11.0",
    "next": "latest",
    "next-themes": "^0.4.6",
    "pdf-parse": "^2.4.5",
    "pino": "^10.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-easy-crop": "^5.5.6",
    "react-grab": "^0.0.91",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "env-cmd": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.3.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5"
  }
}
