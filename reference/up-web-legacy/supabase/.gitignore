# Supabase ディレクトリ用 .gitignore

# ============================================
# 環境変数ファイル（機密情報）
# ============================================
# .env
# .env.local
# .env.*.local

# ============================================
# ボリュームデータ（データベース、ストレージの実データ）
# ============================================
volumes/
# volumes/* は Git で管理しない
# データはマイグレーション + seed.sql で再現可能

# ============================================
# Supabase CLI 生成ファイル
# ============================================
.temp/
.branches/
.logs/

# ============================================
# バックアップファイル（ローカル開発用）
# ============================================
*.backup
*.dump
*.sql.gz

# ============================================
# 一時ファイル
# ============================================
*.log
*.tmp
.DS_Store
