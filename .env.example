# =============================================
# AI Hub - 環境変数設定ファイル
# このファイルを .env.local にコピーして使用してください
# =============================================

# ===== Supabase（必須） =====
# https://supabase.com/ でプロジェクトを作成
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===== Google OAuth（Supabase Auth連携） =====
# https://console.cloud.google.com/apis/credentials から取得
# リダイレクトURI: https://your-project.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ===== LLM API Keys =====

# Google AI Studio（Gemini）- オプション
# https://aistudio.google.com/app/apikey で無料枠のAPIキーを取得
GEMINI_API_KEY=your_gemini_api_key_here

# xAI Grok（必須）
# https://x.ai/api で取得
XAI_API_KEY=your_xai_api_key_here

# Perplexity（エビデンス検索用）- オプション
# https://www.perplexity.ai/settings/api で取得
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ===== オプション（未使用）=====
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================
# Preview環境専用設定（E2Eテスト・手動確認用）
# =============================================
# ⚠️ 以下の環境変数は Preview 環境（VERCEL_ENV=preview）でのみ使用されます
# Production 環境には設定しないでください（セキュリティリスク）

# Preview環境でのみ有効化されるメール/パスワード認証
# E2Eテスト用の固定ユーザー
PREVIEW_E2E_USER=preview-test@example.com
PREVIEW_E2E_PASS=your-secure-preview-password

# Playwright E2Eテスト用
# ローカルテスト時: http://localhost:3000
# Vercel Previewデプロイ時: 自動設定されるため不要
PLAYWRIGHT_BASE_URL=http://localhost:3000

# ローカルでPreviewモードをテストする場合
# NEXT_PUBLIC_VERCEL_ENV=preview
