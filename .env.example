# =============================================
# AI Hub - 環境変数設定ファイル
# このファイルを .env.local にコピーして使用してください
# =============================================

# ===== 必須項目 =====

# Google OAuth 認証
# https://console.cloud.google.com/apis/credentials から取得
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# NextAuth 設定
# 秘密鍵生成: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# データベース（Neon Free Tier）
# https://neon.tech/ で作成したデータベースURL
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# Upstash Redis（キャッシュ・レート制限用）
# https://upstash.com/ で作成（無料枠: 10,000コマンド/日）
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# ===== LLM API Keys =====

# Google AI Studio（Gemini）- 必須
# https://aistudio.google.com/app/apikey で無料枠のAPIキーを取得
# 無料枠: Gemini 2.5 Flash-Lite / Gemini 3.0 Flash 各 30 RPM / 1,500 RPD
GEMINI_API_KEY=your_gemini_api_key_here

# ===== 有料API（必要に応じて追加） =====

# xAI Grok（PJ-C X検索用）
# https://x.ai/api で取得（$25無料クレジット付き）
XAI_API_KEY=your_xai_api_key_here

# Perplexity（PJ-C エビデンス検索用）
# https://www.perplexity.ai/settings/api で取得
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# OpenAI（オプション）→これはいったん使わない
# https://platform.openai.com/api-keys で取得
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic（オプション）→これはいったん使わない
# https://console.anthropic.com/settings/keys で取得
ANTHROPIC_API_KEY=your_anthropic_api_key_here
